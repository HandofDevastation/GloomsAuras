Libs\LibDBIcon-1.0\LibDBIcon-1.0.lua
Libs\LibSharedMedia-3.0\LibSharedMedia-3.0.lua
Libs\LibCustomGlow-1.0\LibCustomGlow-1.0.lua

# Load order: Core (namespace + slash router) → Displays (frames) → CDM (mirror
# engine) → Config (options panel) → MinimapButton (LibDBIcon launcher).
Core.lua
Displays.lua
CDM.lua
Media\TextureManifest.lua
